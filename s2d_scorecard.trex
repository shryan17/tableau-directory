<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <desktop-extension id="com.intuit.tableau.s2d-scorecard" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name">S2D Scorecard</name>
    <description>TTL Funnel S2D Scorecard — rich cell view with counts, conversion %, and avg days in stage.</description>
    <author name="Shane Ryan" email="shane_ryan@intuit.com" organization="Intuit" website="https://shryan17.github.io/tableau-directory" />
    <min-api-version>1.4</min-api-version>
    <source-location>
      <url>https://shryan17.github.io/tableau-directory/s2d_scorecard_extension.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAACXBIWXMAAAsTAAALEwEAmpwYAAAAB3RJTUUH4QMRAiUWODCBAAAAGXRFWHRDb21tZW50AENyZWF0ZWQgd2l0aCBHSU1QV4EOFwAAAEFJREFUOMtjYBgFgx8AERAAAf8DGQLEAAsBAAC2AAEBlgAAAABJRU5ErkJggg==</icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </desktop-extension>
</manifest>
